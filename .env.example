# Solana RPC endpoint (use Helius or other premium RPC)
RPC_URL=https://api.mainnet-beta.solana.com

# Pyth oracle RPC
PYTHNET_URL=https://pythnet.rpcpool.com

# Wallet keypair path (Solana CLI format)
WALLET_PATH=~/.config/solana/id.json

# Anthropic API key for AI interpreter
ANTHROPIC_API_KEY=sk-ant-...

# Default pool (Crypto.1, Virtual.1, Governance.1, Community.1, etc.)
DEFAULT_POOL=Crypto.1

# Network (mainnet-beta or devnet)
NETWORK=mainnet-beta

# Simulation mode (true = paper trading, false = real transactions)
SIMULATION_MODE=true

# Default slippage in basis points (800 = 0.8%)
DEFAULT_SLIPPAGE_BPS=800

# Compute unit limit for transactions
COMPUTE_UNIT_LIMIT=600000

# Compute unit price in microLamports
COMPUTE_UNIT_PRICE=50000
