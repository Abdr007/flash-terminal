# ─── Solana Connection ────────────────────────────────────────────────────────
# RPC endpoint — use a premium provider (Helius, Triton, QuickNode) for reliability
RPC_URL=https://api.mainnet-beta.solana.com

# Backup RPC endpoint (optional, used for failover)
# BACKUP_RPC_URL=

# Pyth oracle RPC endpoint
PYTHNET_URL=https://pythnet.rpcpool.com

# Network: mainnet-beta or devnet
NETWORK=mainnet-beta

# ─── Wallet ──────────────────────────────────────────────────────────────────
# Path to Solana CLI keypair (JSON format)
WALLET_PATH=~/.config/solana/id.json

# ─── Trading ─────────────────────────────────────────────────────────────────
# Simulation mode (true = paper trading, false = real transactions)
# IMPORTANT: Defaults to true. Set to false only when you're ready for live trading.
SIMULATION_MODE=true

# Default trading pool
DEFAULT_POOL=Crypto.1

# Default slippage in basis points (150 = 1.5%)
DEFAULT_SLIPPAGE_BPS=150

# ─── Compute Budget ─────────────────────────────────────────────────────────
# Transaction compute unit limit
COMPUTE_UNIT_LIMIT=600000

# Priority fee in microLamports
COMPUTE_UNIT_PRICE=50000

# ─── Signing Guards ─────────────────────────────────────────────────────────
# Maximum collateral per single trade in USD (0 = unlimited)
MAX_COLLATERAL_PER_TRADE=0

# Maximum position size in USD (0 = unlimited)
MAX_POSITION_SIZE=0

# Maximum leverage multiplier (0 = unlimited)
MAX_LEVERAGE=0

# Maximum trades per minute
MAX_TRADES_PER_MINUTE=10

# Minimum delay between trades in milliseconds
MIN_DELAY_BETWEEN_TRADES_MS=3000

# ─── AI Features ─────────────────────────────────────────────────────────────
# AI API key for natural language command parsing & trade suggestions
# Leave empty to use local regex parsing only (all features work without AI)
ANTHROPIC_API_KEY=

# Groq API key (optional fallback AI provider)
GROQ_API_KEY=

# ─── Logging ─────────────────────────────────────────────────────────────────
# Optional log file path (leave empty for console-only logging)
LOG_FILE=
